#!/bin/sh
# Stub rc-service for s6-overlay compatibility with ACF
# Maps rc-service commands to s6-svc commands

S6_SERVICE_DIR="@S6_RUN_DIR@"
SERVICE_DEF_DIR="@S6_SERVICE_DIR@"

if [ $# -lt 2 ]; then
    echo "Usage: rc-service <service> <action>" >&2
    exit 1
fi

SERVICE="$1"
ACTION="$2"

# Special handling for common services that might not be in s6
# but ACF expects to be able to query
check_special_service() {
    case "$SERVICE" in
        crond|dcron)
            if pgrep -x crond >/dev/null; then
                return 0 # running
            fi
            return 1 # stopped
            ;;
        *)
            return 2 # not a special service
            ;;
    esac
}

# Check if service exists in s6
if [ ! -d "$SERVICE_DEF_DIR/$SERVICE" ]; then
    # Handle status queries for special services (like cron)
    if [ "$ACTION" = "status" ]; then
        check_special_service
        RET=$?
        if [ $RET -eq 0 ]; then
            echo " * status: started"
            exit 0
        elif [ $RET -eq 1 ]; then
            echo " * status: stopped"
            exit 0
        fi
        # If not special, return stopped gracefully for ACF
        echo " * status: stopped"
        exit 0
    fi
    
    # For other actions on non-existent services, report error
    echo "Service $SERVICE not found" >&2
    exit 1
fi

case "$ACTION" in
    start)
        # s6 services are always running, but we can send a restart signal
        if [ -d "$S6_SERVICE_DIR/$SERVICE" ]; then
            s6-svc -u "$S6_SERVICE_DIR/$SERVICE"
            echo " * Starting $SERVICE ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    stop)
        # Stop the service (s6 will restart it if it's supervised)
        if [ -d "$S6_SERVICE_DIR/$SERVICE" ]; then
            s6-svc -d "$S6_SERVICE_DIR/$SERVICE"
            echo " * Stopping $SERVICE ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    restart)
        # Restart the service (s6-svc -t sends SIGTERM and s6 restarts)
        if [ -d "$S6_SERVICE_DIR/$SERVICE" ]; then
            s6-svc -t "$S6_SERVICE_DIR/$SERVICE"
            echo " * Restarting $SERVICE ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    reload)
        # Reload the service (s6-svc -h sends SIGHUP)
        if [ -d "$S6_SERVICE_DIR/$SERVICE" ]; then
            s6-svc -h "$S6_SERVICE_DIR/$SERVICE"
            echo " * Reloading $SERVICE configuration ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    status)
        # Check service status via s6-svstat
        if [ -d "$S6_SERVICE_DIR/$SERVICE" ]; then
            STATUS=$(s6-svstat "$S6_SERVICE_DIR/$SERVICE" 2>&1)
            if echo "$STATUS" | grep -q "up"; then
                echo " * status: started"
            else
                echo " * status: stopped"
            fi
        else
            # Try pgrep as fallback
            if pgrep -x "$SERVICE" >/dev/null; then
                 echo " * status: started"
            else
                 echo " * status: stopped"
            fi
        fi
        ;;
    *)
        echo "Usage: rc-service <service> {start|stop|restart|reload|status}" >&2
        exit 1
        ;;
esac

exit 0
