#!/bin/sh
# Stub rc-service for s6-overlay compatibility with ACF
# Maps rc-service commands to s6-svc commands

SERVICE_DEF_DIR="@S6_SERVICE_DIR@"

# Detect s6 binary location - HA base image uses /package/admin/s6/command
if [ -x "/package/admin/s6/command/s6-svc" ]; then
    _s6_bin="/package/admin/s6/command"
else
    _s6_bin="/usr/bin"
fi

# Detect s6 supervise dir - HA s6-overlay uses /run/s6/legacy-services
if [ -d "/run/s6/legacy-services" ]; then
    _s6_run="/run/s6/legacy-services"
else
    _s6_run="@S6_RUN_DIR@"
fi

if [ $# -lt 2 ]; then
    echo "Usage: rc-service <service> <action>" >&2
    exit 1
fi

SERVICE="$1"
ACTION="$2"

# Special handling for common services that might not be in s6
# but ACF expects to be able to query
check_special_service() {
    case "$SERVICE" in
        crond|dcron)
            if pgrep -x crond >/dev/null; then
                return 0 # running
            fi
            return 1 # stopped
            ;;
        *)
            return 2 # not a special service
            ;;
    esac
}

# Check if service exists in s6
if [ ! -d "$SERVICE_DEF_DIR/$SERVICE" ]; then
    # Handle status queries for special services (like cron)
    if [ "$ACTION" = "status" ]; then
        check_special_service
        RET=$?
        if [ $RET -eq 0 ]; then
            echo " * status: started"
            exit 0
        elif [ $RET -eq 1 ]; then
            echo " * status: stopped"
            exit 0
        fi
        # If not special, return stopped gracefully for ACF
        echo " * status: stopped"
        exit 0
    fi

    # For other actions on non-existent services, report error
    echo "Service $SERVICE not found" >&2
    exit 1
fi

case "$ACTION" in
    start)
        if [ -d "$_s6_run/$SERVICE" ]; then
            "$_s6_bin"/s6-svc -u "$_s6_run/$SERVICE"
            echo " * Starting $SERVICE ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    stop)
        if [ -d "$_s6_run/$SERVICE" ]; then
            "$_s6_bin"/s6-svc -d "$_s6_run/$SERVICE"
            echo " * Stopping $SERVICE ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    restart)
        if [ -d "$_s6_run/$SERVICE" ]; then
            "$_s6_bin"/s6-svc -t "$_s6_run/$SERVICE"
            echo " * Restarting $SERVICE ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    reload)
        if [ -d "$_s6_run/$SERVICE" ]; then
            "$_s6_bin"/s6-svc -h "$_s6_run/$SERVICE"
            echo " * Reloading $SERVICE configuration ..."
        else
            echo "Service $SERVICE not supervised by s6" >&2
            exit 1
        fi
        ;;
    status)
        if [ -d "$_s6_run/$SERVICE" ]; then
            STATUS=$("$_s6_bin"/s6-svstat "$_s6_run/$SERVICE" 2>&1)
            if echo "$STATUS" | grep -q "up"; then
                echo " * status: started"
            else
                echo " * status: stopped"
            fi
        else
            if pgrep -x "$SERVICE" >/dev/null; then
                echo " * status: started"
            else
                echo " * status: stopped"
            fi
        fi
        ;;
    *)
        echo "Usage: rc-service <service> {start|stop|restart|reload|status}" >&2
        exit 1
        ;;
esac

exit 0
