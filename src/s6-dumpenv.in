#!/usr/bin/with-contenv sh
# Export s6-overlay environment to a file for use by cron jobs or other shells
# Usage: Run this during container initialization

ENV_FILE="@SYSCONFDIR@/environment.s6"

# Get all environment variables from s6-env and format them for shell sourcing
# Excludes internal s6 variables and bashio variables that might be too large
s6-dumpenv -- /run/s6/container_environment | 
grep -vE '^(S6_|BASHIO_|PATH=)' > "$ENV_FILE"

# Append a clean PATH if needed
echo "PATH=$PATH" >> "$ENV_FILE"

chmod 644 "$ENV_FILE"
echo "Environment exported to $ENV_FILE"
